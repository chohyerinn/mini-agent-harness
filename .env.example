# CLOVA Studio API credentials — required to run the CLOVA agent.
# Either variable works; CLOVASTUDIO_API_KEY is checked first, then CLOVA_API_KEY.
CLOVASTUDIO_API_KEY=
CLOVA_API_KEY=
CLOVA_BASE_URL=https://clovastudio.stream.ntruss.com/v1/openai
CLOVA_MODEL=HCX-005

# Pytest scoring: "local" runs on the host, "docker" runs in an isolated container.
HARNESS_PYTEST_MODE=local
HARNESS_PYTEST_TIMEOUT=300

# Docker sandbox limits (used only when HARNESS_PYTEST_MODE=docker).
HARNESS_DOCKER_IMAGE=mini-agent-harness-pytest:latest
HARNESS_DOCKER_CPUS=1
HARNESS_DOCKER_MEMORY=512m
HARNESS_DOCKER_PIDS=128
